        "---\n",
        "\n",
        "# Spend-Conversion Relationship\n",
        "\n",
        "## Lagged Correlation Analysis\n",
        "\n",
        "The optimal lag identifies the typical timeframe for advertising effects to materialize in conversions. This analysis motivates the adstock transformation used in the model."
      ],
      "id": "924f33bf"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "lag_corrs_full = []\n",
        "for lag in range(22):\n",
        "    if lag < len(daily_df):\n",
        "        corr = daily_df['TOTAL_SPEND'].iloc[:-lag].reset_index(drop=True).corr(\n",
        "            daily_df['CONVERSIONS'].iloc[lag:].reset_index(drop=True)\n",
        "        )\n",
        "        lag_corrs_full.append({'lag': lag, 'correlation': corr})\n",
        "    else:\n",
        "        lag_corrs_full.append({'lag': lag, 'correlation': np.nan})\n",
        "\n",
        "lag_corrs_full_df = pd.DataFrame(lag_corrs_full)\n",
        "best_lag_idx = lag_corrs_full_df['correlation'].idxmax()\n",
        "best_lag_val = lag_corrs_full_df.loc[best_lag_idx, 'lag']\n",
        "best_corr_val = lag_corrs_full_df.loc[best_lag_idx, 'correlation']\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(12, 6))\n",
        "ax.plot(lag_corrs_full_df['lag'], lag_corrs_full_df['correlation'], linewidth=2, marker='o', markersize=6, color='steelblue')\n",
        "ax.axvline(x=best_lag_val, linestyle='--', color='red', alpha=0.7, linewidth=2)\n",
        "ax.plot(best_lag_val, best_corr_val, marker='o', markersize=10, color='red')\n",
        "ax.text(best_lag_val + 0.5, best_corr_val - 0.02, f'Peak: {int(best_lag_val)} days\\nr = {best_corr_val:.3f}',\n",
        "        fontsize=10, color='red')\n",
        "ax.set_title('Spend-to-Conversion Lag Analysis', fontsize=13, fontweight='bold')\n",
        "ax.set_xlabel('Lag (days)')\n",
        "ax.set_ylabel('Correlation (Pearson r)')\n",
        "ax.grid(True, alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "98cb7a03",
      "execution_count": null,
      "outputs": []
    },
